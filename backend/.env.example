# ── Ollama ────────────────────────────────────────────────────
# Using 127.0.0.1 (not "localhost") avoids a Windows-specific IPv6-first
# DNS resolution delay that can make Ollama appear "unreachable" even when
# it's running fine — see comment in app/core/config.py for details.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Model for chat/generation. phi3:mini loads fastest on CPU-only hardware.
# Other options if pulled: mistral:7b (better quality, slower), llama3.1
# (best quality, ~40s cold-load on CPU — may need higher timeouts).
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Database ──────────────────────────────────────────────────
# Option A: SQLite (easiest for POC - no install needed, just works)
DATABASE_URL=sqlite+aiosqlite:///./smartqa.db

# Option B: PostgreSQL (uncomment and comment out SQLite above)
# DATABASE_URL=postgresql+asyncpg://smartqa:smartqa123@localhost:5432/smartqa_db

# ── ChromaDB (in-process - no server needed) ──────────────────
CHROMA_COLLECTION_REQUIREMENTS=smartqa_requirements
CHROMA_COLLECTION_TESTCASES=smartqa_testcases

# ── App ───────────────────────────────────────────────────────
SECRET_KEY=changeme-secret-key-32chars-min!!
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://localhost:3002"]

# ── Optional: JIRA integration ────────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Optional: Confluence integration ───────────────────────────
# Only needed if your Confluence access uses different credentials than
# JIRA above. If left blank, JIRA_BASE_URL/EMAIL/API_TOKEN are used as a
# fallback (common for orgs where both share the same Atlassian account).
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
